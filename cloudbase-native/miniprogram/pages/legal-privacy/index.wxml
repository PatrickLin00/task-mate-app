<view class="legal-page">
  <view class="legal-shell">
    <view class="legal-card">
      <view class="legal-page-title">{{content.pageTitle}}</view>
      <view class="legal-meta">{{legalStrings.updatedLabel}}：{{legalStrings.updatedAt}}</view>
      <view class="legal-meta">{{legalStrings.effectiveLabel}}：{{legalStrings.effectiveAt}}</view>
      <view class="legal-intro">{{content.intro}}</view>
    </view>

    <view wx:for="{{content.sections}}" wx:key="title" class="legal-card">
      <view class="legal-section-title">{{item.title}}</view>
      <view wx:for="{{item.paragraphs}}" wx:key="index" class="legal-paragraph">{{item}}</view>
    </view>

    <view class="legal-footer">
      <text class="legal-link" bindtap="openPrivacyGuide">{{content.guideLink}}</text>
    </view>
  </view>
</view>
