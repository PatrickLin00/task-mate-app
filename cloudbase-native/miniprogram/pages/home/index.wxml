  <view wx:if="{{onboarding.visible}}" class="guide-overlay" bindtap="onGuideBackdropTap">
    <view class="guide-mask {{onboarding.panelPosition === 'bottom' ? 'guide-mask-bottom-dim' : 'guide-mask-top-dim'}}"></view>
    <view class="guide-panel card {{onboarding.panelPosition === 'bottom' ? 'guide-panel-bottom' : 'guide-panel-top'}}" catchtap="noop">
      <view class="section-title">{{strings.onboarding.title}}</view>
      <view class="task-meta">{{strings.onboardingExtra.overlayHint}}</view>
      <view class="guide-step-title">{{onboarding.title}}</view>
      <view class="task-meta">
        <text wx:for="{{onboarding.segments}}" wx:key="index" class="{{item.strong ? 'guide-strong' : ''}}">{{item.text}}</text>
      </view>
      <view class="task-meta" wx:if="{{onboarding.hint}}">{{onboarding.hint}}</view>
      <view class="guide-actions">
        <button hover-class="button-press" hover-stay-time="90" class="ghost-button guide-action-button" bindtap="skipOnboarding">{{strings.onboarding.skip}}</button>
        <button hover-class="button-press" hover-stay-time="90" wx:if="{{onboarding.step > 0}}" class="ghost-button guide-action-button" bindtap="prevOnboardingStep">{{strings.onboarding.prev}}</button>
        <button hover-class="button-press" hover-stay-time="90" wx:if="{{onboarding.actionDriven && onboarding.step < 13}}" class="ghost-button guide-action-button" bindtap="nextOnboardingStep">{{strings.onboarding.next}}</button>
        <button hover-class="button-press" hover-stay-time="90" wx:if="{{!onboarding.actionDriven && onboarding.step < 13}}" class="primary-button guide-action-button" bindtap="nextOnboardingStep">{{strings.onboarding.next}}</button>
        <button hover-class="button-press" hover-stay-time="90" wx:if="{{onboarding.step === 13}}" class="primary-button guide-action-button" loading="{{actionLoading === 'completeOnboarding'}}" bindtap="finishOnboarding">{{strings.onboarding.finish}}</button>
      </view>
    </view>
  </view>

  <view wx:if="{{error}}" class="error {{errorCollapsed ? 'error-collapsed' : 'error-expanded'}}">
    <view class="error-head" bindtap="toggleErrorCollapse">
      <view class="error-toggle-stack">
        <view class="error-toggle-arrow up {{errorCollapsed ? 'hidden' : 'shown'}}">{{strings.icons.arrowUp}}</view>
        <view class="error-toggle-arrow down {{errorCollapsed ? 'shown' : 'hidden'}}">{{strings.icons.arrowDown}}</view>
      </view>
    </view>
    <view class="error-body {{errorCollapsed ? 'error-body-hidden' : 'error-body-visible'}}">{{error}}</view>
  </view>

  <view wx:if="{{scrollHints.page && !detailMounted && !create.visible && !profileEditVisible && !subscribeSettings.visible && !onboarding.visible}}" class="scroll-hint scroll-hint-page">
    <view class="scroll-hint-fade"></view>
    <view class="scroll-hint-arrow">{{strings.icons.arrowDown}}</view>
  </view>

  <view wx:if="{{taskFly.visible}}" class="task-fly-layer">
    <view class="task-fly-card" style="left: {{taskFly.x}}px; top: {{taskFly.y}}px; transform: translate({{taskFly.tx}}px, {{taskFly.ty}}px) scale({{taskFly.scale}}); opacity: {{taskFly.opacity}};">
      <view class="task-fly-title">{{taskFly.title}}</view>
    </view>
  </view>
