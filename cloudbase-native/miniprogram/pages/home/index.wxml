<scroll-view
  class="page-scroll"
  scroll-y="true"
  enhanced="true"
  show-scrollbar="false"
  refresher-enabled="true"
  refresher-triggered="{{refreshing}}"
  bindrefresherrefresh="onPullDownRefresh"
  bindscroll="onPageScrollView"
>
<view class="page-scroll-content">
<view class="page-shell">
  <view class="hero card {{heroCollapsed ? 'collapsed' : ''}} {{onboarding.visible && onboarding.target === 'hero' ? 'guide-target' : ''}}">
    <view class="hero-toolbar">
      <view class="eyebrow">{{strings.hero.eyebrow}}</view>
      <view class="hero-toggle" bindtap="toggleHeroCollapse">
        <view class="hero-toggle-stack">
          <view class="hero-toggle-arrow up {{heroCollapsed ? 'hidden' : 'shown'}}">{{strings.icons.arrowUp}}</view>
          <view class="hero-toggle-arrow down {{heroCollapsed ? 'shown' : 'hidden'}}">{{strings.icons.arrowDown}}</view>
        </view>
      </view>
    </view>

    <view class="hero-expanded {{heroCollapsed ? 'hero-panel-hidden' : 'hero-panel-visible'}}">
      <view class="hero-top">
        <view class="hero-copy">
          <view class="title">{{profile.nickname || strings.common.unnamedTraveler}}</view>
          <view class="section-subtitle">{{strings.hero.intro}}</view>
        </view>
        <button hover-class="button-press" hover-stay-time="90" class="primary-button mini-button hero-create-inline {{onboarding.visible && (onboarding.target === 'hero' || onboarding.target === 'create-entry') ? 'guide-target' : ''}}" bindtap="openCreateModal">{{strings.hero.createTask}}</button>
      </view>

      <view class="hero-stats">
        <view class="stat">
          <view class="stat-value">{{profile.wisdom || 0}}</view>
          <view class="stat-label">{{strings.hero.wisdom}}</view>
        </view>
        <view class="stat">
          <view class="stat-value">{{profile.strength || 0}}</view>
          <view class="stat-label">{{strings.hero.strength}}</view>
        </view>
        <view class="stat">
          <view class="stat-value">{{profile.agility || 0}}</view>
          <view class="stat-label">{{strings.hero.agility}}</view>
        </view>
        <view class="stat">
          <view class="stat-value">{{dashboard.summary.totalOpen || 0}}</view>
          <view class="stat-label">{{strings.hero.totalOpen}}</view>
        </view>
      </view>
    </view>

    <view class="hero-collapsed {{heroCollapsed ? 'hero-panel-visible' : 'hero-panel-hidden'}}">
      <view class="hero-mini-row">
        <view class="hero-mini-name">{{profile.nickname || strings.common.unnamedTraveler}}</view>
        <view class="hero-mini-metrics">
          <view class="hero-mini-metric">{{strings.hero.strengthMini}}: {{profile.strength || 0}}</view>
          <view class="hero-mini-metric">{{strings.hero.wisdomMini}}: {{profile.wisdom || 0}}</view>
          <view class="hero-mini-metric">{{strings.hero.agilityMini}}: {{profile.agility || 0}}</view>
          <view class="hero-mini-metric">{{strings.hero.totalMini}}: {{dashboard.summary.totalOpen || 0}}</view>
        </view>
      </view>

      <view class="hero-create-row">
        <button hover-class="button-press" hover-stay-time="90" class="primary-button hero-create-full {{onboarding.visible && (onboarding.target === 'hero' || onboarding.target === 'create-entry') ? 'guide-target' : ''}}" bindtap="openCreateModal">{{strings.hero.createTask}}</button>
      </view>
    </view>
  </view>

  <view class="tabs card">
    <view id="tab-home" class="tab {{activeTab === 'home' ? 'active' : ''}} {{tabPulseTab === 'home' ? 'tab-pulse' : ''}} {{onboarding.visible && onboarding.target === 'home' ? 'guide-target' : ''}}" data-tab="home" bindtap="setTab">{{strings.tabs.home}}</view>
    <view id="tab-mission" class="tab {{activeTab === 'mission' ? 'active' : ''}} {{tabPulseTab === 'mission' ? 'tab-pulse' : ''}} {{onboarding.visible && onboarding.target === 'mission-list' ? 'guide-target' : ''}}" data-tab="mission" bindtap="setTab">{{strings.tabs.mission}}</view>
    <view id="tab-collab" class="tab {{activeTab === 'collab' ? 'active' : ''}} {{tabPulseTab === 'collab' ? 'tab-pulse' : ''}} {{onboarding.visible && onboarding.target === 'collab-list' ? 'guide-target' : ''}}" data-tab="collab" bindtap="setTab">{{strings.tabs.collab}}</view>
    <view id="tab-archive" class="tab {{activeTab === 'archive' ? 'active' : ''}} {{tabPulseTab === 'archive' ? 'tab-pulse' : ''}} {{onboarding.visible && onboarding.target === 'archive-list' ? 'guide-target' : ''}}" data-tab="archive" bindtap="setTab">{{strings.tabs.archive}}</view>
    <view id="tab-achievements" class="tab {{activeTab === 'achievements' ? 'active' : ''}} {{tabPulseTab === 'achievements' ? 'tab-pulse' : ''}} {{onboarding.visible && onboarding.target === 'achievements' ? 'guide-target' : ''}}" data-tab="achievements" bindtap="setTab">{{strings.tabs.achievements}}</view>
    <view id="tab-profile" class="tab {{activeTab === 'profile' ? 'active' : ''}} {{tabPulseTab === 'profile' ? 'tab-pulse' : ''}} {{onboarding.visible && onboarding.target === 'profile' ? 'guide-target' : ''}}" data-tab="profile" bindtap="setTab">{{strings.tabs.profile}}</view>
  </view>

  <view class="tab-stage" animation="{{tabAnimation}}">
    <block wx:if="{{activeTab === 'home'}}">
      <view class="tab-pane">
        <view class="card section-card {{onboarding.visible && onboarding.target === 'home' ? 'guide-target guide-home-pane' : ''}}">
          <view class="section-title">{{strings.home.todayTitle}}</view>
          <view class="section-subtitle">{{strings.home.todaySubtitle}}</view>
          <view class="task-list" wx:if="{{view.todayTasks.length}}">
            <view wx:for="{{view.todayTasks}}" wx:key="_id" class="task-item" data-task-id="{{item._id}}" data-source="{{item.source}}" bindtap="openTask">
              <view class="task-head">
                <view class="task-title">{{item.title}}</view>
                <view class="task-status">{{item.statusText}}</view>
              </view>
              <view class="task-meta">{{strings.detail.dueAt}} {{item.dueText}}<text wx:if="{{item.overdueDaysText}}" class="task-overdue-text"> {{item.overdueDaysText}}</text></view>
              <view class="task-meta">{{strings.archive.progress}} {{item.progressText}}</view>
            </view>
          </view>
          <view class="empty" wx:else>{{strings.home.todayEmpty}}</view>
        </view>

        <view class="card section-card {{onboarding.visible && onboarding.target === 'home' ? 'guide-target guide-home-pane' : ''}}">
          <view class="daily-task-section-head">
            <view>
              <view class="section-title">{{strings.home.challengeTitle}}</view>
              <view class="section-subtitle">{{strings.home.challengeSubtitle}}</view>
            </view>
            <button hover-class="button-press" hover-stay-time="90" class="ghost-button mini-button daily-task-edit-button" bindtap="toggleDailyTaskEditMode">{{dailyTaskEditor.editMode ? strings.common.done : strings.home.challengeEditButton}}</button>
          </view>

          <view wx:if="{{dailyTaskEditor.editMode || view.challengeTasks.length}}" class="daily-task-body">
            <view class="task-list daily-task-view-list">
              <block wx:if="{{dailyTaskEditor.editMode}}">
                <view wx:for="{{dailyTaskEditor.presets}}" wx:key="id" wx:for-item="preset" wx:for-index="presetIndex" class="task-item daily-task-summary-card" data-index="{{presetIndex}}" bindtap="onTapDailyTaskPresetCard">
                  <view class="daily-task-card-main">
                    <view class="daily-task-card-copy">
                      <view class="daily-task-card-title">{{preset.title || (strings.dailyTaskSettings.presetTitle + ' ' + (presetIndex + 1))}}</view>
                      <view class="task-meta daily-task-card-detail">{{preset.detail}}</view>
                      <view class="task-meta daily-task-card-reward">{{strings.home.challengeReward}} {{preset.rewardType === 'strength' ? strings.create.rewardStrength : (preset.rewardType === 'agility' ? strings.create.rewardAgility : strings.create.rewardWisdom)}} +1</view>
                    </view>
                    <view class="daily-task-editor-card-actions">
                      <button hover-class="button-press" hover-stay-time="90" size="mini" class="ghost-button mini-button" data-index="{{presetIndex}}" catchtap="toggleDailyTaskPresetEditor">{{dailyTaskEditor.expandedIndex === presetIndex ? strings.common.cancel : strings.common.edit}}</button>
                      <button hover-class="button-press" hover-stay-time="90" size="mini" class="ghost-button mini-button daily-task-editor-action-button {{dailyTaskEditor.deletingIndex === presetIndex ? 'daily-task-editor-action-button-loading' : ''}}" data-index="{{presetIndex}}" catchtap="deleteDailyTaskPreset">{{strings.dailyTaskSettings.deletePreset}}</button>
                    </view>
                  </view>
                  <view wx:if="{{dailyTaskEditor.expandedIndex === presetIndex || dailyTaskEditor.openingIndex === presetIndex || dailyTaskEditor.closingIndex === presetIndex}}" class="daily-task-editor-panel {{dailyTaskEditor.expandedIndex === presetIndex ? 'daily-task-editor-panel-open' : (dailyTaskEditor.openingIndex === presetIndex ? 'daily-task-editor-panel-opening' : 'daily-task-editor-panel-closing')}}" catchtap="noop">
                    <view class="daily-task-editor-group">
                      <view class="section-subtitle">{{strings.dailyTaskSettings.aiPromptLabel}}</view>
                      <textarea class="input area" placeholder="{{strings.dailyTaskSettings.aiPromptPlaceholder}}" value="{{preset.aiPrompt}}" data-index="{{presetIndex}}" bindinput="onDailyTaskPresetAiPromptInput" />
                      <button hover-class="button-press" hover-stay-time="90" class="ghost-button create-footer-button" loading="{{actionLoading === ('generateDailyTaskDraft_' + presetIndex)}}" data-index="{{presetIndex}}" bindtap="onGenerateDailyTaskPresetDraft">{{strings.dailyTaskSettings.aiGenerate}}</button>
                    </view>
                    <view class="daily-task-editor-group">
                      <view class="section-subtitle">{{strings.dailyTaskSettings.titleLabel}}</view>
                      <input class="input" placeholder="{{strings.dailyTaskSettings.titlePlaceholder}}" value="{{preset.title}}" data-index="{{presetIndex}}" bindinput="onDailyTaskPresetTitleInput" />
                    </view>
                    <view class="daily-task-editor-group">
                      <view class="section-subtitle">{{strings.dailyTaskSettings.detailLabel}}</view>
                      <textarea class="input area" placeholder="{{strings.dailyTaskSettings.detailPlaceholder}}" value="{{preset.detail}}" data-index="{{presetIndex}}" bindinput="onDailyTaskPresetDetailInput" />
                    </view>
                    <view class="daily-task-editor-group">
                      <view class="section-subtitle">{{strings.dailyTaskSettings.dueTimeLabel}}</view>
                      <picker mode="time" value="{{preset.dueTime}}" data-index="{{presetIndex}}" bindchange="onDailyTaskPresetDueTimeChange">
                        <view class="picker">{{preset.dueTime}}</view>
                      </picker>
                    </view>
                    <view class="daily-task-editor-group">
                      <view class="section-subtitle">{{strings.dailyTaskSettings.rewardLabel}}</view>
                      <view class="reward-types">
                        <view class="reward-chip {{preset.rewardType === 'wisdom' ? 'active' : ''}}" data-index="{{presetIndex}}" data-type="wisdom" bindtap="onDailyTaskPresetRewardTypeChange">{{strings.create.rewardWisdom}}</view>
                        <view class="reward-chip {{preset.rewardType === 'strength' ? 'active' : ''}}" data-index="{{presetIndex}}" data-type="strength" bindtap="onDailyTaskPresetRewardTypeChange">{{strings.create.rewardStrength}}</view>
                        <view class="reward-chip {{preset.rewardType === 'agility' ? 'active' : ''}}" data-index="{{presetIndex}}" data-type="agility" bindtap="onDailyTaskPresetRewardTypeChange">{{strings.create.rewardAgility}}</view>
                      </view>
                    </view>
                    <view class="daily-task-editor-group">
                      <view class="section-subtitle">{{strings.dailyTaskSettings.subtasksLabel}}</view>
                      <view wx:for="{{preset.subtasks}}" wx:key="index" wx:for-item="subtask" wx:for-index="itemIndex" class="subtask-edit-row">
                        <input class="input flex-input" placeholder="{{strings.dailyTaskSettings.subtaskPlaceholder}}" value="{{subtask.title}}" data-preset-index="{{presetIndex}}" data-subtask-index="{{itemIndex}}" bindinput="onDailyTaskPresetSubtaskInput" />
                        <view class="input number-input daily-task-fixed-total">1</view>
                        <button hover-class="button-press" hover-stay-time="90" size="mini" class="ghost-button mini-button delete-step-button" data-preset-index="{{presetIndex}}" data-subtask-index="{{itemIndex}}" bindtap="removeDailyTaskSubtask">{{strings.actions.removeStep}}</button>
                      </view>
                      <button hover-class="button-press" hover-stay-time="90" class="ghost-button create-footer-button" data-index="{{presetIndex}}" bindtap="addDailyTaskSubtask">{{strings.actions.addStep}}</button>
                    </view>
                    <view class="daily-task-editor-group">
                      <view class="subscribe-category-head">
                        <view>
                          <view class="section-subtitle subscribe-category-title">{{strings.dailyTaskSettings.autoAcceptLabel}}</view>
                          <view class="task-meta subscribe-category-copy">{{strings.dailyTaskSettings.autoAcceptHint}}</view>
                        </view>
                        <switch color="#b86b24" checked="{{preset.autoAccept}}" data-index="{{presetIndex}}" bindchange="onDailyTaskPresetAutoAcceptChange" />
                      </view>
                    </view>
                    <view wx:if="{{preset.autoAccept}}" class="daily-task-editor-group">
                      <view class="section-subtitle">{{strings.dailyTaskSettings.autoAcceptTimeLabel}}</view>
                      <picker mode="time" value="{{preset.autoAcceptTime}}" data-index="{{presetIndex}}" bindchange="onDailyTaskPresetAutoAcceptTimeChange">
                        <view class="picker">{{preset.autoAcceptTime}}</view>
                      </picker>
                    </view>
                    <view class="create-footer-actions daily-task-inline-actions">
                      <button hover-class="button-press" hover-stay-time="90" class="ghost-button create-footer-button" bindtap="cancelDailyTaskPresetEdit">{{strings.common.cancel}}</button>
                      <button hover-class="button-press" hover-stay-time="90" class="primary-button create-footer-button" loading="{{actionLoading === ('saveDailyTaskSettings_' + presetIndex)}}" data-index="{{presetIndex}}" bindtap="saveDailyTaskSettings">{{strings.profile.save}}</button>
                    </view>
                  </view>
                </view>
              </block>
              <block wx:else>
                <view wx:for="{{view.challengeTasks}}" wx:key="_id" class="task-item daily-task-summary-card" data-task-id="{{item._id}}" data-source="{{item.source}}" data-status="{{item.status}}" data-assignee-id="{{item.assigneeId}}" data-seed-key="{{item.seedKey}}" bindtap="onTapDailyTaskCard">
                  <view class="daily-task-card-main">
                    <view class="daily-task-card-copy">
                      <view class="daily-task-card-title">{{item.title}}</view>
                      <view class="task-meta daily-task-card-detail">{{item.detail}}</view>
                      <view class="task-meta daily-task-card-reward">{{strings.home.challengeReward}} {{item.rewardText}}</view>
                    </view>
                    <view class="daily-task-card-side">
                      <view class="task-status daily-task-card-status">{{item.isVirtual ? strings.home.challengeVirtual : item.statusText}}</view>
                      <button hover-class="button-press" hover-stay-time="90" wx:if="{{item.status === 'pending' && !item.assigneeId && item.seedKey}}" size="mini" class="primary-button mini-button daily-task-side-button {{pendingChallengeAcceptMap[item.seedKey] ? 'daily-task-side-button-loading' : ''}}" data-seed-key="{{item.seedKey}}" catchtap="onAcceptChallenge">
                        <text>{{strings.home.challengeAccept}}</text>
                      </button>
                    </view>
                  </view>
                </view>
              </block>
            </view>

            <view class="daily-task-add-wrap {{dailyTaskEditor.editMode ? 'daily-task-add-wrap-visible' : 'daily-task-add-wrap-hidden'}}">
              <button hover-class="button-press" hover-stay-time="90" class="ghost-button create-footer-button daily-task-add-button" bindtap="addDailyTaskPreset">{{strings.dailyTaskSettings.addPreset}}</button>
            </view>
          </view>
          <view class="empty" wx:elif="{{!dailyTaskEditor.editMode}}">{{strings.home.challengeEmpty}}</view>
        </view>
      </view>
    </block>

    <block wx:elif="{{activeTab === 'mission'}}">
      <view class="card section-card tab-pane {{onboarding.visible && onboarding.target === 'mission-list' ? 'guide-target' : ''}}">
        <view class="section-title">{{strings.mission.title}}</view>
        <view class="section-subtitle">{{strings.mission.subtitle}}</view>
        <view class="task-list" wx:if="{{view.missionTasks.length}}">
          <view wx:for="{{view.missionTasks}}" wx:key="_id" class="task-item {{onboarding.visible && onboarding.target === 'mission-list' && item._id === 'guide-mission-task' ? 'guide-target' : ''}}" data-task-id="{{item._id}}" data-source="{{item.source}}" bindtap="openTask">
            <view class="task-head">
              <view class="task-title">{{item.title}}</view>
              <view class="task-status">{{item.statusText}}</view>
            </view>
            <view class="task-meta">{{item.creatorName || strings.common.system}}{{strings.mission.creatorJoin}}{{item.progressText}}</view>
            <view class="task-meta">{{strings.detail.dueAt}} {{item.dueText}}<text wx:if="{{item.overdueDaysText}}" class="task-overdue-text"> {{item.overdueDaysText}}</text></view>
          </view>
        </view>
        <view class="empty" wx:else>{{strings.mission.empty}}</view>
      </view>
    </block>

    <block wx:elif="{{activeTab === 'collab'}}">
      <view class="card section-card tab-pane {{onboarding.visible && onboarding.target === 'collab-list' ? 'guide-target' : ''}}">
        <view class="section-title">{{strings.collab.title}}</view>
        <view class="section-subtitle">{{strings.collab.subtitle}}</view>
        <view wx:if="{{view.reviewPendingTasks.length}}" class="history-block">
          <view class="section-subtitle">{{strings.collab.reviewPendingTitle || '待检视'}}</view>
          <view class="task-list">
            <view wx:for="{{view.reviewPendingTasks}}" wx:key="_id" class="task-item" data-task-id="{{item._id}}" data-source="{{item.source}}" bindtap="openTask">
              <view class="task-head">
                <view class="task-title">{{item.title}}</view>
                <view class="task-status">{{item.statusText}}</view>
              </view>
              <view class="task-meta">{{item.assigneeName ? (strings.collab.assigneePrefix + item.assigneeName) : strings.collab.waitingAccept}}</view>
              <view class="task-meta">{{strings.detail.dueAt}} {{item.dueText}}<text wx:if="{{item.overdueDaysText}}" class="task-overdue-text"> {{item.overdueDaysText}}</text></view>
            </view>
          </view>
        </view>
        <view wx:if="{{view.pendingConfirmationTasks.length}}" class="history-block">
          <view class="section-subtitle">{{strings.collab.pendingConfirmationTitle || '待确认'}}</view>
          <view class="task-list">
            <view wx:for="{{view.pendingConfirmationTasks}}" wx:key="_id" class="task-item" data-task-id="{{item._id}}" data-source="{{item.source}}" bindtap="openTask">
              <view class="task-head">
                <view class="task-title">{{item.title}}</view>
                <view class="task-status">{{item.statusText}}</view>
              </view>
              <view class="task-meta">{{item.assigneeName ? (strings.collab.assigneePrefix + item.assigneeName) : strings.collab.waitingAccept}}</view>
              <view class="task-meta">{{strings.detail.dueAt}} {{item.dueText}}<text wx:if="{{item.overdueDaysText}}" class="task-overdue-text"> {{item.overdueDaysText}}</text></view>
            </view>
          </view>
        </view>
        <view wx:if="{{view.waitingAcceptTasks.length}}" class="history-block">
          <view class="section-subtitle">{{strings.collab.waitingAcceptTitle || '待接取'}}</view>
          <view class="task-list">
            <view wx:for="{{view.waitingAcceptTasks}}" wx:key="_id" class="task-item {{onboarding.visible && onboarding.target === 'collab-list' && item._id === 'guide-collab-task' ? 'guide-target' : ''}}" data-task-id="{{item._id}}" data-source="{{item.source}}" bindtap="openTask">
              <view class="task-head">
                <view class="task-title">{{item.title}}</view>
                <view class="task-status">{{item.statusText}}</view>
              </view>
              <view class="task-meta">{{item.assigneeName ? (strings.collab.assigneePrefix + item.assigneeName) : strings.collab.waitingAccept}}</view>
              <view class="task-meta">{{strings.detail.dueAt}} {{item.dueText}}<text wx:if="{{item.overdueDaysText}}" class="task-overdue-text"> {{item.overdueDaysText}}</text></view>
            </view>
          </view>
        </view>
        <view wx:if="{{view.inProgressCollabTasks.length}}" class="history-block">
          <view class="section-subtitle">{{strings.collab.inProgressTitle || '进行中'}}</view>
          <view class="task-list">
            <view wx:for="{{view.inProgressCollabTasks}}" wx:key="_id" class="task-item" data-task-id="{{item._id}}" data-source="{{item.source}}" bindtap="openTask">
              <view class="task-head">
                <view class="task-title">{{item.title}}</view>
                <view class="task-status">{{item.statusText}}</view>
              </view>
              <view class="task-meta">{{item.assigneeName ? (strings.collab.assigneePrefix + item.assigneeName) : strings.collab.waitingAccept}}</view>
              <view class="task-meta">{{strings.detail.dueAt}} {{item.dueText}}<text wx:if="{{item.overdueDaysText}}" class="task-overdue-text"> {{item.overdueDaysText}}</text></view>
            </view>
          </view>
        </view>
        <view class="task-list" wx:if="{{!view.reviewPendingTasks.length && !view.pendingConfirmationTasks.length && !view.waitingAcceptTasks.length && !view.inProgressCollabTasks.length && view.collabTasks.length}}">
          <view wx:for="{{view.collabTasks}}" wx:key="_id" class="task-item {{onboarding.visible && onboarding.target === 'collab-list' && item._id === 'guide-collab-task' ? 'guide-target' : ''}}" data-task-id="{{item._id}}" data-source="{{item.source}}" bindtap="openTask">
            <view class="task-head">
              <view class="task-title">{{item.title}}</view>
              <view class="task-status">{{item.statusText}}</view>
            </view>
            <view class="task-meta">{{item.assigneeName ? (strings.collab.assigneePrefix + item.assigneeName) : strings.collab.waitingAccept}}</view>
            <view class="task-meta">{{strings.detail.dueAt}} {{item.dueText}}<text wx:if="{{item.overdueDaysText}}" class="task-overdue-text"> {{item.overdueDaysText}}</text></view>
          </view>
        </view>
        <view class="empty" wx:if="{{!view.reviewPendingTasks.length && !view.pendingConfirmationTasks.length && !view.waitingAcceptTasks.length && !view.inProgressCollabTasks.length && !view.historyTasks.length}}">{{strings.collab.empty}}</view>

        <view wx:if="{{view.historyTasks.length}}" class="history-block">
          <view class="section-subtitle">{{strings.collab.historyTitle}}</view>
          <view class="task-list">
            <view wx:for="{{view.historyTasks}}" wx:key="_id" class="task-item" data-task-id="{{item._id}}" data-source="{{item.source}}" bindtap="openTask">
              <view class="task-head">
                <view class="task-title">{{item.title}}</view>
                <view class="task-status">{{item.statusText}}</view>
              </view>
              <view class="task-meta">{{strings.collab.createdAt}} {{item.dueText}}</view>
            </view>
          </view>
        </view>
      </view>
    </block>

    <block wx:elif="{{activeTab === 'archive'}}">
      <view class="card section-card tab-pane {{onboarding.visible && onboarding.target === 'archive-list' ? 'guide-target' : ''}}">
        <view class="section-title">{{strings.archive.title}}</view>
        <view class="section-subtitle">{{strings.archive.subtitle}}</view>
        <view class="task-list" wx:if="{{view.archiveTasks.length}}">
          <view wx:for="{{view.archiveTasks}}" wx:key="_id" class="task-item archive-item {{onboarding.visible && onboarding.target === 'archive-list' && item._id === 'guide-archive-task' ? 'guide-target' : ''}}" data-task-id="{{item._id}}" data-source="archive" bindtap="openTask">
            <view class="task-head">
              <view class="task-title">{{item.title}}</view>
              <view class="task-status">{{item.statusText}}</view>
            </view>
            <view class="task-meta">{{strings.archive.recordedAt}} {{item.finishedText}}</view>
            <view class="task-meta">{{strings.archive.progress}} {{item.progressText}}</view>
          </view>
        </view>
        <view class="empty" wx:else>{{strings.archive.empty}}</view>
      </view>
    </block>

    <block wx:elif="{{activeTab === 'achievements'}}">
      <view class="card section-card tab-pane {{onboarding.visible && onboarding.target === 'achievements' ? 'guide-target' : ''}}">
        <view class="section-title">{{strings.achievements.title}}</view>
        <view class="section-subtitle">{{strings.achievements.subtitle}}</view>
        <view class="achievement-grid">
          <view class="achievement-item">
            <view class="achievement-title">{{strings.achievements.wisdom}}</view>
            <view class="task-meta">{{strings.achievements.currentPointsPrefix}}{{profile.wisdom || 0}}{{strings.achievements.currentPointsSuffix}}</view>
          </view>
          <view class="achievement-item">
            <view class="achievement-title">{{strings.achievements.strength}}</view>
            <view class="task-meta">{{strings.achievements.currentPointsPrefix}}{{profile.strength || 0}}{{strings.achievements.currentPointsSuffix}}</view>
          </view>
