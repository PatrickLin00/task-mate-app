.hero,
.tabs,
.section-card {
  margin-top: 14rpx;
}

.hero {
  transition: all 0.24s ease;
}

.hero-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.hero-top,
.task-head,
.task-actions,
.modal-head,
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-expanded,
.hero-collapsed {
  margin-top: 10rpx;
  overflow: hidden;
  transition: max-height 0.24s ease, opacity 0.2s ease, transform 0.24s ease, margin-top 0.24s ease;
}

.hero-expanded.hero-panel-visible {
  max-height: 520rpx;
  opacity: 1;
  transform: translateY(0);
}

.hero-expanded.hero-panel-hidden {
  max-height: 0;
  opacity: 0;
  margin-top: 0;
  transform: translateY(-10rpx);
}

.hero-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.hero-toggle-stack {
  position: relative;
  width: 18rpx;
  height: 18rpx;
}

.hero-toggle-arrow {
  position: absolute;
  inset: 0;
  color: #9d6a34;
  font-size: 18rpx;
  line-height: 1;
  text-align: center;
  transition: opacity 0.18s ease;
}

.hero-toggle-arrow.hidden {
  opacity: 0;
}

.hero-toggle-arrow.shown {
  opacity: 1;
}

.eyebrow {
  color: #7f5a2a;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.title {
  margin-top: 8rpx;
  font-size: 48rpx;
  font-weight: 700;
}

.hero-create-inline {
  flex-shrink: 0;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 14rpx;
}

.stat {
  padding: 16rpx 14rpx;
  border-radius: 20rpx;
  background: var(--bg-soft);
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 6rpx;
  color: var(--ink-subtle);
  font-size: 26rpx;
  line-height: 1.3;
}

.hero-mini-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.hero-mini-name {
  flex-shrink: 0;
  max-width: 220rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
}

.hero-mini-metrics {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10rpx 14rpx;
}

.hero-mini-metric {
  color: var(--ink-subtle);
  font-size: 22rpx;
  line-height: 1.4;
}

.hero-create-row {
  margin-top: 12rpx;
}

.hero-create-full {
  width: 100%;
}

.hero-collapsed.hero-panel-visible {
  max-height: 180rpx;
  opacity: 1;
  transform: translateY(0);
}

.hero-collapsed.hero-panel-hidden {
  max-height: 0;
  opacity: 0;
  margin-top: 0;
  transform: translateY(-6rpx);
}

.tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.tab {
  padding: 14rpx 0;
  border-radius: 18rpx;
  background: rgba(255, 247, 235, 0.8);
  color: var(--ink-subtle);
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
}

.tab.active {
  background: var(--accent);
  color: #fff8ef;
}

.tab-pane {
  display: grid;
  gap: 14rpx;
}

.tab-stage {
  transform: translateY(0);
}

.task-list {
  margin-top: 12rpx;
}

.task-item {
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(111, 84, 50, 0.12);
}

.task-item:first-child {
  border-top: 0;
}

.task-title,
.subtask-title {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.35;
}

.section-card > .section-title {
  margin-bottom: 6rpx;
}

.task-status {
  color: var(--accent-strong);
  font-size: 22rpx;
}

.task-meta,
.empty {
  margin-top: 6rpx;
  color: var(--ink-subtle);
  font-size: 24rpx;
  line-height: 1.5;
}

.inline-actions {
  margin-top: 10rpx;
}

.history-block {
  margin-top: 14rpx;
  border-top: 1rpx solid rgba(111, 84, 50, 0.12);
  padding-top: 10rpx;
}

.achievement-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 12rpx;
}

.achievement-item,
.profile-block {
  padding: 16rpx;
  border-radius: 20rpx;
  background: var(--bg-soft);
}

.profile-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.profile-action-row.single {
  grid-template-columns: 1fr;
}

.profile-action-button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  margin: 0;
  box-sizing: border-box;
}

.profile-action-button::after {
  border: 0;
}

.achievement-title {
  font-size: 26rpx;
  font-weight: 600;
}

.mini-button {
  margin: 0;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx;
  background: rgba(19, 14, 10, 0.3);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease;
}

.modal-mask.modal-open {
  opacity: 1;
  pointer-events: auto;
}

.modal-mask.modal-closing {
  opacity: 0;
  pointer-events: none;
}

.create-mask {
  align-items: flex-start;
  padding-top: 166rpx;
}

.modal {
  width: 100%;
  max-height: 88vh;
  height: 88vh;
  overflow: hidden;
  transform: translateY(160rpx);
  will-change: transform;
  transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
}

.modal-scroll {
  box-sizing: border-box;
}

.modal-mask.modal-open .modal {
  transform: translateY(0);
}

.modal-mask.modal-closing .modal {
  transform: translateY(160rpx);
}

.create-mask .modal {
  height: calc(100vh - 220rpx);
  max-height: calc(100vh - 220rpx);
  opacity: 0;
  transform: translateY(-28rpx) scale(0.94);
  transform-origin: calc(100% - 84rpx) 0;
  transition:
    transform 0.24s cubic-bezier(0.2, 0.9, 0.28, 1),
    opacity 0.2s ease;
}

.create-mask.modal-open .modal {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.create-mask.modal-closing .modal {
  opacity: 0;
  transform: translateY(-20rpx) scale(0.94);
}

.create-modal {
  padding-bottom: 42rpx;
}

.create-modal .input,
.create-modal .row,
.create-modal .reward-types,
.create-modal .subtasks,
.create-modal .check-line,
.create-modal button,
.create-modal checkbox-group {
  margin-top: 16rpx;
}

.input,
.picker {
  width: 100%;
  box-sizing: border-box;
  min-height: 84rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fffdf8;
  line-height: 48rpx;
}

.area {
  width: 100%;
  min-height: 140rpx;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
  line-height: 1.45;
}

.create-modal .picker {
  display: flex;
  align-items: center;
}

.reward-fixed {
  margin-top: 14rpx;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 253, 248, 0.92);
  color: var(--ink-subtle);
  font-size: 28rpx;
  line-height: 1.35;
}

.actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
  align-items: stretch;
}

.actions > button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  box-sizing: border-box;
  margin: 0;
}

.actions > button::after {
  border: 0;
}

.progress-action-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  width: 100%;
  align-items: stretch;
  grid-column: 1 / -1;
}

.secondary-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  width: 100%;
  align-items: stretch;
  grid-column: 1 / -1;
}

.secondary-action-row > button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  box-sizing: border-box;
  margin: 0;
}

.secondary-action-row > button::after {
  border: 0;
}

.progress-action-button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  box-sizing: border-box;
  margin: 0;
  padding-left: 0;
  padding-right: 0;
  font-size: 26rpx;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.progress-action-row .progress-action-button::after {
  border: 0;
}

.subtasks,
.reward-types {
  margin-top: 16rpx;
}

.subtask-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 14rpx 0;
  border-top: 1rpx solid rgba(111, 84, 50, 0.12);
}

.subtask-row:first-child {
  border-top: 0;
}

.subtask-main {
  flex: 1;
  min-width: 0;
}

.subtask-actions {
  display: flex;
  gap: 10rpx;
}

.subtask-edit-row {
  display: grid;
  grid-template-columns: 1fr 120rpx 96rpx;
  gap: 12rpx;
  margin-top: 12rpx;
}

.flex-input {
  min-width: 0;
}

.number-input {
  width: 120rpx;
}

.create-footer-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
  margin-bottom: 18rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 10rpx);
  align-items: stretch;
}

.create-footer-button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  display: block;
  margin: 0;
  box-sizing: border-box;
  padding-left: 0;
  padding-right: 0;
}

.create-footer-actions .create-footer-button::after {
  border: 0;
}

.reward-types {
  display: flex;
  gap: 12rpx;
}

.reward-chip {
  padding: 16rpx 22rpx;
  border: 2rpx solid rgba(150, 95, 35, 0.16);
  border-radius: 999rpx;
  background: rgba(255, 248, 238, 0.92);
  color: var(--accent-strong);
  font-size: 28rpx;
  line-height: 1.2;
}

.reward-chip.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff8ef;
}

.check-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: var(--ink-subtle);
  font-size: 28rpx;
  line-height: 1.35;
}

.create-modal .section-subtitle {
  font-size: 28rpx;
  line-height: 1.35;
}

.create-modal checkbox {
  transform: scale(0.95);
}

.delete-step-button {
  min-width: 84rpx;
  width: 84rpx;
  height: 84rpx;
  padding: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  line-height: 1;
  text-align: center;
}

.delete-step-button::after {
  border: 0;
}

.error {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 26rpx;
  z-index: 40;
  border-radius: 20rpx;
  background: rgba(179, 72, 50, 0.92);
  box-shadow: 0 16rpx 36rpx rgba(70, 26, 16, 0.18);
  color: #fff7f2;
  overflow: hidden;
  transition: opacity 0.18s ease;
}

.error-expanded {
  opacity: 1;
}

.error-collapsed {
  opacity: 1;
}

.error-head {
  display: flex;
  justify-content: flex-end;
  min-height: 30rpx;
  padding: 10rpx 18rpx 6rpx;
}

.error-toggle-stack {
  position: relative;
  width: 20rpx;
  height: 20rpx;
}

.error-toggle-arrow {
  position: absolute;
  inset: 0;
  color: #fff4ed;
  font-size: 20rpx;
  line-height: 1;
  text-align: center;
  transition: opacity 0.18s ease;
}

.error-toggle-arrow.hidden {
  opacity: 0;
}

.error-toggle-arrow.shown {
  opacity: 1;
}

.guide-overlay {
  position: fixed;
  inset: 0;
  z-index: 50;
  pointer-events: none;
}

.guide-mask {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.guide-mask-bottom-dim {
  background: linear-gradient(
    to bottom,
    rgba(255, 248, 239, 0.02) 0%,
    rgba(255, 248, 239, 0.04) 42%,
    rgba(82, 58, 28, 0.22) 58%,
    rgba(82, 58, 28, 0.28) 100%
  );
}

.guide-mask-top-dim {
  background: linear-gradient(
    to bottom,
    rgba(82, 58, 28, 0.22) 0%,
    rgba(82, 58, 28, 0.28) 42%,
    rgba(255, 248, 239, 0.04) 58%,
    rgba(255, 248, 239, 0.02) 100%
  );
}

.guide-target {
  position: relative;
  z-index: 52;
  box-shadow:
    0 0 0 8rpx rgba(255, 252, 247, 1),
    0 0 0 18rpx rgba(214, 144, 63, 0.34),
    0 0 42rpx rgba(236, 182, 92, 0.42),
    0 24rpx 56rpx rgba(52, 30, 12, 0.34);
  outline: 4rpx solid rgba(255, 242, 221, 0.98);
  animation: guideGlow 1.4s ease-in-out infinite;
}

.guide-home-pane {
  border-radius: 28rpx;
}

.guide-panel {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  z-index: 53;
  padding: 24rpx;
  pointer-events: auto;
}

.guide-panel-top {
  top: 140rpx;
}

.guide-panel-bottom {
  bottom: 34rpx;
}

.guide-step-title {
  margin-top: 16rpx;
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.guide-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 20rpx;
}

.guide-action-button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  margin: 0;
  box-sizing: border-box;
  white-space: nowrap;
  font-size: 28rpx;
  line-height: 1.2;
  padding-left: 0;
  padding-right: 0;
}

.guide-action-button::after {
  border: 0;
}

.guide-strong {
  font-weight: 700;
  color: var(--ink);
}

@keyframes guideGlow {
  0% {
    box-shadow:
      0 0 0 8rpx rgba(255, 252, 247, 1),
      0 0 0 18rpx rgba(214, 144, 63, 0.24),
      0 0 24rpx rgba(236, 182, 92, 0.18),
      0 18rpx 42rpx rgba(52, 30, 12, 0.22);
    outline-color: rgba(255, 242, 221, 0.86);
  }
  50% {
    box-shadow:
      0 0 0 8rpx rgba(255, 252, 247, 1),
      0 0 0 20rpx rgba(214, 144, 63, 0.42),
      0 0 50rpx rgba(236, 182, 92, 0.46),
      0 24rpx 56rpx rgba(52, 30, 12, 0.34);
    outline-color: rgba(255, 242, 221, 1);
  }
  100% {
    box-shadow:
      0 0 0 8rpx rgba(255, 252, 247, 1),
      0 0 0 18rpx rgba(214, 144, 63, 0.24),
      0 0 24rpx rgba(236, 182, 92, 0.18),
      0 18rpx 42rpx rgba(52, 30, 12, 0.22);
    outline-color: rgba(255, 242, 221, 0.86);
  }
}

.error-body {
  padding: 0 22rpx 18rpx;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
  transition: max-height 0.22s ease, opacity 0.18s ease, transform 0.22s ease, padding 0.22s ease;
}

.error-body-visible {
  max-height: 220rpx;
  opacity: 1;
  transform: translateY(0);
}

.error-body-hidden {
  max-height: 0;
  opacity: 0;
  transform: translateY(10rpx);
  padding-top: 0;
  padding-bottom: 0;
}
