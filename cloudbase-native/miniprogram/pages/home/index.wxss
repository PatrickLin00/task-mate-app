.hero,
.tabs,
.section-card {
  margin-top: 14rpx;
}

.hero {
  transition: all 0.24s ease;
}

.hero-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.hero-top,
.task-head,
.task-actions,
.modal-head,
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-expanded,
.hero-collapsed {
  margin-top: 10rpx;
  overflow: hidden;
  transition: max-height 0.24s ease, opacity 0.2s ease, transform 0.24s ease, margin-top 0.24s ease;
}

.hero-expanded.hero-panel-visible {
  max-height: 520rpx;
  opacity: 1;
  transform: translateY(0);
}

.hero-expanded.hero-panel-hidden {
  max-height: 0;
  opacity: 0;
  margin-top: 0;
  transform: translateY(-10rpx);
}

.hero-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.hero-toggle-stack {
  position: relative;
  width: 18rpx;
  height: 18rpx;
}

.hero-toggle-arrow {
  position: absolute;
  inset: 0;
  color: #9d6a34;
  font-size: 18rpx;
  line-height: 1;
  text-align: center;
  transition: opacity 0.18s ease;
}

.hero-toggle-arrow.hidden {
  opacity: 0;
}

.hero-toggle-arrow.shown {
  opacity: 1;
}

.eyebrow {
  color: #7f5a2a;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.title {
  margin-top: 8rpx;
  font-size: 48rpx;
  font-weight: 700;
}

.hero-create-inline {
  flex-shrink: 0;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 14rpx;
}

.stat {
  padding: 16rpx 14rpx;
  border-radius: 20rpx;
  background: var(--bg-soft);
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 6rpx;
  color: var(--ink-subtle);
  font-size: 26rpx;
  line-height: 1.3;
}

.hero-mini-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.hero-mini-name {
  flex-shrink: 0;
  max-width: 220rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
}

.hero-mini-metrics {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10rpx 14rpx;
}

.hero-mini-metric {
  color: var(--ink-subtle);
  font-size: 22rpx;
  line-height: 1.4;
}

.hero-create-row {
  margin-top: 12rpx;
}

.hero-create-full {
  width: 100%;
}

.hero-collapsed.hero-panel-visible {
  max-height: 180rpx;
  opacity: 1;
  transform: translateY(0);
}

.hero-collapsed.hero-panel-hidden {
  max-height: 0;
  opacity: 0;
  margin-top: 0;
  transform: translateY(-6rpx);
}

.tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.tab {
  padding: 14rpx 0;
  border-radius: 18rpx;
  background: rgba(255, 247, 235, 0.8);
  color: var(--ink-subtle);
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
}

.tab.active {
  background: var(--accent);
  color: #fff8ef;
}

.tab.tab-pulse {
  animation: tabPulse 0.72s ease;
}

.tab-pane {
  display: grid;
  gap: 14rpx;
}

.tab-stage {
  transform: translateY(0);
}

.page-scroll-content,
.detail-scroll-content,
.create-scroll-content,
.profile-scroll-content {
  position: relative;
  min-height: 100%;
}

.page-scroll-content {
  padding-bottom: calc(env(safe-area-inset-bottom) + 28rpx);
  box-sizing: border-box;
}

.task-list {
  margin-top: 12rpx;
  display: grid;
  gap: 12rpx;
}

.daily-task-section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.daily-task-edit-button {
  margin: 0;
  flex-shrink: 0;
  align-self: center;
}

.task-item {
  padding: 18rpx 18rpx 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, var(--bg-task) 0%, var(--bg-task-strong) 100%);
  box-shadow:
    inset 0 0 0 1rpx rgba(137, 96, 47, 0.12),
    0 10rpx 24rpx rgba(92, 58, 24, 0.05);
}

.task-item:nth-child(even) {
  background: linear-gradient(180deg, var(--bg-task-alt) 0%, var(--bg-task-alt-strong) 100%);
}

.task-item:first-child {
  border-top: 0;
}

.task-title,
.subtask-title {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.35;
}

.section-card > .section-title {
  margin-bottom: 6rpx;
}

.task-status {
  color: var(--accent-strong);
  font-size: 22rpx;
}

.task-meta,
.empty {
  margin-top: 6rpx;
  color: var(--ink-subtle);
  font-size: 24rpx;
  line-height: 1.5;
}

.task-overdue-text {
  color: #c65a38;
  font-weight: 600;
}

.modal .task-meta {
  margin-top: 10rpx;
}

.modal .task-meta + .task-meta {
  margin-top: 12rpx;
}

.detail-summary {
  margin-top: 14rpx;
  display: grid;
  gap: 14rpx;
  padding: 4rpx 0;
}

.detail-group {
  display: grid;
  gap: 6rpx;
}

.detail-line {
  margin-top: 0 !important;
  padding: 0;
}

.inline-actions {
  margin-top: 10rpx;
}

.history-block {
  margin-top: 14rpx;
  border-top: 1rpx solid rgba(111, 84, 50, 0.12);
  padding-top: 10rpx;
}

.achievement-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 12rpx;
}

.achievement-item,
.profile-block {
  padding: 16rpx;
  border-radius: 20rpx;
  background: var(--bg-soft);
}

.profile-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.profile-action-row.single {
  grid-template-columns: 1fr;
}

.profile-action-button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  margin: 0;
  box-sizing: border-box;
}

.profile-action-button::after {
  border: 0;
}

.subscribe-settings-list {
  display: grid;
  gap: 14rpx;
  margin-top: 18rpx;
}

.subscribe-mask {
  align-items: flex-start;
  padding-top: 120rpx;
}

.subscribe-mask .modal {
  height: calc(100vh - 180rpx);
  max-height: calc(100vh - 180rpx);
  opacity: 0;
  transform: translateY(-28rpx) scale(0.96);
  transform-origin: center top;
  transition:
    transform 0.24s cubic-bezier(0.2, 0.9, 0.28, 1),
    opacity 0.2s ease;
}

.subscribe-mask.modal-open .modal {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.subscribe-mask.modal-closing .modal {
  opacity: 0;
  transform: translateY(-20rpx) scale(0.96);
}

.daily-task-scroll .task-meta + .task-meta {
  margin-top: 12rpx;
}

.daily-task-body {
  margin-top: 12rpx;
  overflow: hidden;
}

.daily-task-editor-list {
  display: grid;
  gap: 16rpx;
}

.daily-task-view-list {
  margin-top: 0;
}

.daily-task-add-wrap {
  overflow: hidden;
  transition: max-height 0.22s ease, opacity 0.18s ease, margin-top 0.22s ease;
}

.daily-task-add-wrap-visible {
  max-height: 120rpx;
  opacity: 1;
  margin-top: 16rpx;
}

.daily-task-add-wrap-hidden {
  max-height: 0;
  opacity: 0;
  margin-top: 0;
}

.daily-task-summary-card {
  position: relative;
  overflow: hidden;
  padding-bottom: 8rpx;
}

.daily-task-card-main {
  display: block;
  position: relative;
  min-height: 144rpx;
}

.daily-task-card-copy {
  min-width: 0;
  padding-right: 140rpx;
}

.daily-task-card-title {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.daily-task-card-detail {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  max-height: 72rpx;
  min-height: 72rpx;
}

.daily-task-card-reward {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.daily-task-card-side {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 118rpx;
}

.daily-task-card-status {
  position: absolute;
  top: 0;
  right: 0;
  margin: 0;
  text-align: right;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.daily-task-side-button {
  position: absolute;
  right: 0;
  bottom: 0;
  width: auto;
  min-width: 0;
  margin: 0;
  padding: 0 18rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: padding 0.18s ease;
}

.daily-task-side-button::after {
  border: 0;
}

.daily-task-side-button-loading {
  opacity: 0.82;
}

@keyframes dailyTaskButtonSpin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.daily-task-editor-card-main {
  position: relative;
  min-height: 144rpx;
}

.daily-task-editor-card-copy {
  min-width: 0;
  padding-right: 140rpx;
}

.daily-task-editor-card-title {
  padding-right: 12rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.daily-task-editor-card-detail {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  max-height: 72rpx;
  min-height: 72rpx;
}

.daily-task-editor-card-reward {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.daily-task-editor-card-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 118rpx;
}

.daily-task-editor-card-actions .ghost-button {
  position: absolute;
  right: 0;
  margin: 0;
}

.daily-task-editor-card-actions .ghost-button:first-child {
  top: 0;
}

.daily-task-editor-card-actions .ghost-button:last-child {
  bottom: 0;
}

.daily-task-editor-panel {
  margin-top: 18rpx;
  padding-top: 18rpx;
  padding-bottom: 0;
  border-top: 1rpx solid rgba(111, 84, 50, 0.12);
  overflow: hidden;
  transform-origin: top center;
  transition: max-height 0.22s ease, opacity 0.18s ease, transform 0.22s ease, margin-top 0.22s ease, padding-top 0.22s ease;
}

.daily-task-editor-panel-open {
  max-height: 2200rpx;
  opacity: 1;
  transform: translateY(0);
}

.daily-task-editor-panel-opening,
.daily-task-editor-panel-closing {
  max-height: 0;
  opacity: 0;
  margin-top: 0;
  padding-top: 0;
  transform: translateY(-8rpx);
}

.daily-task-editor-group {
  margin-top: 16rpx;
}

.daily-task-delete-button,
.daily-task-add-button {
  margin: 0;
}

.daily-task-inline-actions {
  margin-top: 10rpx;
  margin-bottom: 6rpx;
  padding-bottom: 0;
}

.daily-task-editor-panel .create-footer-actions {
  margin-bottom: 6rpx;
  padding-bottom: 0;
}

.subscribe-category {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(111, 84, 50, 0.12);
}

.subscribe-category:first-of-type {
  padding-top: 0;
  border-top: 0;
}

.subscribe-category-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.subscribe-head-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.subscribe-category-title {
  margin-top: 0;
  font-size: 28rpx;
  font-weight: 700;
}

.subscribe-category-copy {
  margin-top: 6rpx;
}

.subscribe-category-status {
  margin-top: 6rpx;
  color: var(--accent-strong);
}

.subscribe-add-button {
  margin: 0;
  flex-shrink: 0;
}

.subscribe-rule-row {
  padding: 18rpx;
  border-radius: 20rpx;
  background: var(--bg-soft);
}

.subscribe-direction-group {
  display: flex;
  gap: 12rpx;
}

.subscribe-direction-chip {
  flex: 1;
  padding: 14rpx 0;
  border: 2rpx solid rgba(150, 95, 35, 0.16);
  border-radius: 999rpx;
  background: rgba(255, 248, 238, 0.92);
  color: var(--accent-strong);
  text-align: center;
  font-size: 26rpx;
  line-height: 1.2;
}

.subscribe-direction-chip.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff8ef;
}

.subscribe-reminder-edit-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.subscribe-picker-row {
  flex: 1;
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 12rpx;
}

.subscribe-picker {
  min-height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  text-align: center;
}

.subscribe-delete-button {
  min-width: 112rpx;
  margin: 0;
  padding: 0 22rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.subscribe-delete-button::after {
  border: 0;
}

.subscribe-reminder-summary {
  margin-top: 12rpx !important;
}

.subscribe-authorize-button {
  width: 100%;
  margin-top: 8rpx;
}

.subscribe-reminder-card,
.subscribe-static-card {
  padding-top: 20rpx;
}

.achievement-title {
  font-size: 26rpx;
  font-weight: 600;
}

.mini-button {
  margin: 0;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx;
  background: rgba(19, 14, 10, 0.3);
  opacity: 0;
  pointer-events: none;
  overflow: hidden;
  transition: opacity 0.2s ease;
}

.modal-mask.modal-open {
  opacity: 1;
  pointer-events: auto;
}

.modal-mask.modal-closing {
  opacity: 0;
  pointer-events: none;
}

.create-mask {
  align-items: flex-start;
  padding-top: 166rpx;
}

.modal-stack {
  position: relative;
  width: 100%;
  height: 88vh;
  max-height: 88vh;
}

.modal-stack-create {
  height: calc(100vh - 220rpx);
  max-height: calc(100vh - 220rpx);
}

.modal {
  width: 100%;
  max-height: 88vh;
  height: 88vh;
  overflow: hidden;
  transform: translateY(160rpx);
  will-change: transform;
  transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
}

.modal-scroll {
  box-sizing: border-box;
  position: relative;
}

.modal-mask.modal-open .modal {
  transform: translateY(0);
}

.modal-mask.modal-closing .modal {
  transform: translateY(160rpx);
}

.create-mask .modal {
  height: 100%;
  max-height: 100%;
  opacity: 0;
  transform: translateY(-28rpx) scale(0.94);
  transform-origin: calc(100% - 84rpx) 0;
  transition:
    transform 0.24s cubic-bezier(0.2, 0.9, 0.28, 1),
    opacity 0.2s ease;
}

.create-mask.modal-open .modal {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.create-mask.modal-closing .modal {
  opacity: 0;
  transform: translateY(-20rpx) scale(0.94);
}

.create-modal {
  padding-bottom: 42rpx;
}

.scroll-hint {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  pointer-events: none;
  z-index: 3;
}

.scroll-hint-page {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
}

.scroll-hint-modal {
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  border-bottom-left-radius: 28rpx;
  border-bottom-right-radius: 28rpx;
}

.scroll-hint-modal .scroll-hint-arrow {
  bottom: 10rpx;
}

.scroll-hint-fade {
  width: 100%;
  height: 56rpx;
  background: linear-gradient(180deg, rgba(246, 235, 214, 0), rgba(246, 235, 214, 0.58) 78%, rgba(246, 235, 214, 0.76));
}

.scroll-hint-arrow {
  position: absolute;
  bottom: calc(env(safe-area-inset-bottom) + 8rpx);
  width: 28rpx;
  height: 28rpx;
  color: var(--accent-strong);
  font-size: 16rpx;
  font-weight: 700;
  line-height: 28rpx;
  text-align: center;
  background: transparent;
  box-shadow: none;
  opacity: 0.78;
}

.create-modal .input,
.create-modal .row,
.create-modal .reward-types,
.create-modal .subtasks,
.create-modal .check-line,
.create-modal button,
.create-modal checkbox-group {
  margin-top: 16rpx;
}

.input,
.picker {
  width: 100%;
  box-sizing: border-box;
  min-height: 84rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fffdf8;
  line-height: 48rpx;
}

.area {
  width: 100%;
  min-height: 140rpx;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
  line-height: 1.45;
}

.create-modal .picker {
  display: flex;
  align-items: center;
}

.reward-fixed {
  margin-top: 14rpx;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 253, 248, 0.92);
  color: var(--ink-subtle);
  font-size: 28rpx;
  line-height: 1.35;
}

.offline-reward-input {
  margin-top: 12rpx;
}

.detail-offline-reward {
  color: #3b6fa3;
}

.actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
  align-items: stretch;
}

.actions > button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  box-sizing: border-box;
  margin: 0;
}

.actions > button::after {
  border: 0;
}

.progress-action-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  width: 100%;
  align-items: stretch;
  grid-column: 1 / -1;
}

.secondary-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  width: 100%;
  align-items: stretch;
  grid-column: 1 / -1;
}

.secondary-action-row-triple {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.secondary-action-row > button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  box-sizing: border-box;
  margin: 0;
  padding-left: 0;
  padding-right: 0;
  font-size: 26rpx;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.secondary-action-row > button::after {
  border: 0;
}

.progress-action-button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  box-sizing: border-box;
  margin: 0;
  padding-left: 0;
  padding-right: 0;
  font-size: 26rpx;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.progress-action-row .progress-action-button::after {
  border: 0;
}

.subtasks,
.reward-types {
  margin-top: 16rpx;
}

.subtask-row {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  gap: 12rpx;
  padding: 14rpx 0;
  border-top: 0;
}

.subtask-row:first-child {
  border-top: 0;
}

.subtask-main {
  flex: 1;
  min-width: 0;
}

.subtask-progress-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.subtask-slider-wrap {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 34rpx;
  padding: 0 20rpx 0 28rpx;
  box-sizing: border-box;
}

.subtask-slider-rail,
.subtask-slider-fill {
  position: absolute;
  left: 0;
  top: 50%;
  height: 4rpx;
  border-radius: 999rpx;
  transform: translateY(-50%);
}

.subtask-slider-rail {
  right: 0;
  background: rgba(140, 104, 58, 0.16);
}

.subtask-slider-fill {
  background: var(--accent);
}

.subtask-slider-thumb {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  color: var(--accent-strong);
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1;
  pointer-events: none;
}

.subtask-progress-value {
  margin-top: 0 !important;
  min-width: 72rpx;
  text-align: right;
}

.subtask-edit-row {
  display: grid;
  grid-template-columns: 1fr 120rpx 96rpx;
  gap: 12rpx;
  margin-top: 12rpx;
}

.flex-input {
  min-width: 0;
}

.number-input {
  width: 120rpx;
}

.daily-task-fixed-total {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ink-subtle);
}

.create-footer-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
  margin-bottom: 18rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 10rpx);
  align-items: stretch;
}

.create-footer-button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  display: block;
  margin: 0;
  box-sizing: border-box;
  padding-left: 0;
  padding-right: 0;
}

.create-footer-actions .create-footer-button::after {
  border: 0;
}

.reward-types {
  display: flex;
  gap: 12rpx;
}

.reward-chip {
  padding: 16rpx 22rpx;
  border: 2rpx solid rgba(150, 95, 35, 0.16);
  border-radius: 999rpx;
  background: rgba(255, 248, 238, 0.92);
  color: var(--accent-strong);
  font-size: 28rpx;
  line-height: 1.2;
}

.reward-chip.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff8ef;
}

.check-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: var(--ink-subtle);
  font-size: 28rpx;
  line-height: 1.35;
}

.create-modal .section-subtitle {
  font-size: 28rpx;
  line-height: 1.35;
}

.create-modal checkbox {
  transform: scale(0.95);
}

.delete-step-button {
  min-width: 84rpx;
  width: 84rpx;
  height: 84rpx;
  padding: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  line-height: 1;
  text-align: center;
}

.delete-step-button::after {
  border: 0;
}

.error {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 26rpx;
  z-index: 40;
  border-radius: 20rpx;
  background: rgba(179, 72, 50, 0.92);
  box-shadow: 0 16rpx 36rpx rgba(70, 26, 16, 0.18);
  color: #fff7f2;
  overflow: hidden;
  transition: opacity 0.18s ease;
}

.error-expanded {
  opacity: 1;
}

.error-collapsed {
  opacity: 1;
}

.error-head {
  display: flex;
  justify-content: flex-end;
  min-height: 30rpx;
  padding: 10rpx 18rpx 6rpx;
}

.error-toggle-stack {
  position: relative;
  width: 20rpx;
  height: 20rpx;
}

.error-toggle-arrow {
  position: absolute;
  inset: 0;
  color: #fff4ed;
  font-size: 20rpx;
  line-height: 1;
  text-align: center;
  transition: opacity 0.18s ease;
}

.error-toggle-arrow.hidden {
  opacity: 0;
}

.error-toggle-arrow.shown {
  opacity: 1;
}

.guide-overlay {
  position: fixed;
  inset: 0;
  z-index: 50;
  pointer-events: auto;
}

.guide-mask {
  position: absolute;
  inset: 0;
  pointer-events: auto;
}

.guide-mask-bottom-dim {
  background: linear-gradient(
    to bottom,
    rgba(255, 248, 239, 0.02) 0%,
    rgba(255, 248, 239, 0.04) 42%,
    rgba(82, 58, 28, 0.22) 58%,
    rgba(82, 58, 28, 0.28) 100%
  );
}

.guide-mask-top-dim {
  background: linear-gradient(
    to bottom,
    rgba(82, 58, 28, 0.22) 0%,
    rgba(82, 58, 28, 0.28) 42%,
    rgba(255, 248, 239, 0.04) 58%,
    rgba(255, 248, 239, 0.02) 100%
  );
}

.guide-target {
  position: relative;
  z-index: 52;
  box-shadow:
    0 0 0 8rpx rgba(255, 252, 247, 1),
    0 0 0 18rpx rgba(214, 144, 63, 0.34),
    0 0 42rpx rgba(236, 182, 92, 0.42),
    0 24rpx 56rpx rgba(52, 30, 12, 0.34);
  outline: 4rpx solid rgba(255, 242, 221, 0.98);
  animation: guideGlow 1.4s ease-in-out infinite;
}

.guide-home-pane {
  border-radius: 28rpx;
}

.guide-panel {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  z-index: 53;
  padding: 24rpx;
  pointer-events: auto;
}

.guide-panel-top {
  top: 140rpx;
}

.guide-panel-bottom {
  bottom: 34rpx;
}

.guide-step-title {
  margin-top: 16rpx;
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.guide-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 20rpx;
}

.guide-action-button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  margin: 0;
  box-sizing: border-box;
  white-space: nowrap;
  font-size: 28rpx;
  line-height: 1.2;
  padding-left: 0;
  padding-right: 0;
}

.guide-action-button::after {
  border: 0;
}

.guide-strong {
  font-weight: 700;
  color: var(--ink);
}

.task-fly-layer {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 45;
}

.task-fly-card {
  position: fixed;
  width: 216rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(255, 249, 240, 0.98) 0%, rgba(248, 236, 213, 0.96) 100%);
  box-shadow:
    0 14rpx 32rpx rgba(72, 43, 18, 0.16),
    inset 0 0 0 1rpx rgba(137, 96, 47, 0.14);
  transition:
    transform 0.5s cubic-bezier(0.2, 0.86, 0.26, 1),
    opacity 0.5s ease,
    left 0.5s cubic-bezier(0.2, 0.86, 0.26, 1),
    top 0.5s cubic-bezier(0.2, 0.86, 0.26, 1);
}

.task-fly-title {
  color: var(--ink);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.legal-link-list {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx 28rpx;
}

.legal-link {
  color: #2f6fd6;
  font-size: 26rpx;
  line-height: 1.5;
}

@keyframes guideGlow {
  0% {
    box-shadow:
      0 0 0 8rpx rgba(255, 252, 247, 1),
      0 0 0 18rpx rgba(214, 144, 63, 0.24),
      0 0 24rpx rgba(236, 182, 92, 0.18),
      0 18rpx 42rpx rgba(52, 30, 12, 0.22);
    outline-color: rgba(255, 242, 221, 0.86);
  }
  50% {
    box-shadow:
      0 0 0 8rpx rgba(255, 252, 247, 1),
      0 0 0 20rpx rgba(214, 144, 63, 0.42),
      0 0 50rpx rgba(236, 182, 92, 0.46),
      0 24rpx 56rpx rgba(52, 30, 12, 0.34);
    outline-color: rgba(255, 242, 221, 1);
  }
  100% {
    box-shadow:
      0 0 0 8rpx rgba(255, 252, 247, 1),
      0 0 0 18rpx rgba(214, 144, 63, 0.24),
      0 0 24rpx rgba(236, 182, 92, 0.18),
      0 18rpx 42rpx rgba(52, 30, 12, 0.22);
    outline-color: rgba(255, 242, 221, 0.86);
  }
}

@keyframes tabPulse {
  0% {
    transform: scale(1);
    box-shadow: 0 0 0 rgba(214, 144, 63, 0);
  }
  45% {
    transform: scale(1.08);
    box-shadow: 0 0 0 10rpx rgba(214, 144, 63, 0.18);
  }
  100% {
    transform: scale(1);
    box-shadow: 0 0 0 rgba(214, 144, 63, 0);
  }
}

.error-body {
  padding: 0 22rpx 18rpx;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
  transition: max-height 0.22s ease, opacity 0.18s ease, transform 0.22s ease, padding 0.22s ease;
}

.error-body-visible {
  max-height: 220rpx;
  opacity: 1;
  transform: translateY(0);
}

.error-body-hidden {
  max-height: 0;
  opacity: 0;
  transform: translateY(10rpx);
  padding-top: 0;
  padding-bottom: 0;
}
